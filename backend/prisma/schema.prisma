datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum AttackStatus {
  PENDING
  ACCEPTED
  FORFEITED
  RESOLVED
  EXPIRED
}

enum AttackType {
  SPRINT
  STAT
}

enum ClanRole {
  LEADER
  MEMBER
}

model User {
  id            String   @id @default(uuid())
  clerkId       String   @unique
  email         String   @unique
  name          String?
  avatarUrl     String?
  bio           String?
  totalDistance Float    @default(0)
  totalRuns     Int      @default(0)
  battlesWon    Int      @default(0)
  battlesLost   Int      @default(0)
  fcmToken      String?
  createdAt     DateTime @default(now())

  // Clan relation
  clanId  String?
  clan    Clan?   @relation("ClanMembers", fields: [clanId], references: [id])
  ledClan Clan?   @relation("ClanLeader")

  // Relationships
  runs             Run[]
  territories      Territory[]
  attacksInitiated Attack[]     @relation("Attacker")
  attacksDefended  Attack[]     @relation("Defender")
  attacksWon       Attack[]     @relation("Winner")
  clanMembership   ClanMember[]
  activities       Activity[]
  kudos            Kudos[]
  comments         Comment[]

  @@index([clanId])
}

model Run {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  startedAt        DateTime
  endedAt          DateTime?
  distanceKm       Float
  durationSeconds  Int
  avgPaceMinPerKm  Float
  calories         Int
  gpxPath          Json // Array of {lat, lng, timestamp, speed}
  mapScreenshotUrl String?
  isPublic         Boolean   @default(true)
  createdAt        DateTime  @default(now())

  activity Activity?

  @@index([userId])
}

model Territory {
  id              String   @id @default(uuid())
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id])
  areaM2          Float
  color           String
  acquisitionDate DateTime @default(now())
  lastDefended    DateTime @default(now())

  // Note: The 'polygon' column is added via raw SQL migration
  attacks Attack[]
}

model Attack {
  id          String       @id @default(uuid())
  attackerId  String
  attacker    User         @relation("Attacker", fields: [attackerId], references: [id])
  defenderId  String
  defender    User         @relation("Defender", fields: [defenderId], references: [id])
  territoryId String
  territory   Territory    @relation(fields: [territoryId], references: [id])
  status      AttackStatus @default(PENDING)
  type        AttackType
  scheduledAt DateTime?
  resolvedAt  DateTime?
  winnerId    String?
  winner      User?        @relation("Winner", fields: [winnerId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
}

model Clan {
  id          String   @id @default(uuid())
  name        String
  tag         String   @unique // 4 chars
  leaderId    String   @unique
  leader      User     @relation("ClanLeader", fields: [leaderId], references: [id])
  color       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     User[]       @relation("ClanMembers")
  memberships ClanMember[]
}

model ClanMember {
  clanId   String
  clan     Clan     @relation(fields: [clanId], references: [id])
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  role     ClanRole @default(MEMBER)
  joinedAt DateTime @default(now())

  @@id([clanId, userId])
}

model Activity {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  runId      String   @unique
  run        Run      @relation(fields: [runId], references: [id])
  caption    String?
  photoUrls  String[]
  kudosCount Int      @default(0)
  createdAt  DateTime @default(now())

  kudos    Kudos[]
  comments Comment[]
}

model Kudos {
  id         String   @id @default(uuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([activityId, userId])
}

model Comment {
  id         String   @id @default(uuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id])
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  text       String
  createdAt  DateTime @default(now())
}
