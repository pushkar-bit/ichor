# ── Auth (hand-rolled Google sign-in) ─────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# ID (type: Web application). Both vars hold the same value.
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Random secret for signing session cookies, e.g. `openssl rand -base64 32`.
SESSION_SECRET=

# ── Database (MongoDB Atlas) ──────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/ichor?retryWrites=true&w=majority

# ── AI (Gemini) ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Leaderboard cache (Upstash Redis REST) ───────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Geocoding (LocationIQ) ────────────────────────────────────────────────────
LOCATIONIQ_API_KEY=

# ── Media (Cloudinary — signed browser-direct uploads) ───────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Push (Firebase client config) ────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ── Error tracking (Sentry) ───────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Admin (separate login at /admin/login — unrelated to the Google user auth) ──
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=ICHOR
