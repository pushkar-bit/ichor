# ── Auth (Clerk) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/feed
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/feed

# ── Database (MongoDB Atlas) ──────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/ichor?retryWrites=true&w=majority

# ── AI (Gemini) ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Leaderboard cache (Upstash Redis REST) ───────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Geocoding (LocationIQ) ────────────────────────────────────────────────────
LOCATIONIQ_API_KEY=

# ── Media (Cloudinary — signed browser-direct uploads) ───────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Push (Firebase client config) ────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ── Error tracking (Sentry) ───────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_SECRET=change_me_in_production

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=ICHOR
